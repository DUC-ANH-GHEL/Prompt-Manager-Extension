{
  "manifest_version": 3,
  "name": "Prompt Manager AI Helper",
  "version": "1.0",
  "description": "Store and auto-fill prompts into AI chat interfaces.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "index.html",
    "default_title": "Prompt Manager"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
